# ShuttliX Backend v2.0 — Environment Variables
# Copy this to .env and fill in real values. Never commit .env!

# === Application ===
NODE_ENV=development
PORT=5000

# === Database ===
MONGODB_URI=mongodb://localhost:27017/shuttlix

# === Redis ===
REDIS_URL=redis://localhost:6379

# === JWT Authentication ===
JWT_SECRET=replace_with_64_char_random_secret_use_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_different_64_char_random_secret
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# === Password Hashing ===
BCRYPT_SALT_ROUNDS=12

# === CORS (comma-separated frontend URLs) ===
CLIENT_URLS=http://localhost:5173,https://yourdomain.com

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=ShuttliX <your@gmail.com>

# === Superadmin (first run only) ===
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=strong_password_here
SUPERADMIN_NAME=System Admin
